{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Morseformer",
  "version": "0.1.0",
  "identifier": "com.sderhy.morseformer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Morseformer",
        "width": 920,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": ["resources/**/*"]
  }
}
